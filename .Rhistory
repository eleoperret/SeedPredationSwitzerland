BET_camera_data<-read.csv("Data/CameraData/BET_SeedPredationExperiment_FULL.csv", sep=",")
NEU_camera_data<-read.csv("Data/CameraData/NEU_SeedPredationExperiment_FULL.csv", sep=",")
